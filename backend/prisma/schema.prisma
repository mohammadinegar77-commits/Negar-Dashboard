generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  name          String
  email         String   @unique
  password_hash String?
  role          String?
  created_at    DateTime @default(now())

  @@map("users")
}

model ContentPost {
  id           Int       @id @default(autoincrement())
  title        String
  platform     String
  language     String
  content_type String
  status       String    @default("Draft")
  scheduled_at DateTime?
  assigned_to  String?
  campaign_id  Int?
  created_at   DateTime  @default(now())

  campaign Campaign? @relation(fields: [campaign_id], references: [id], onDelete: SetNull)

  @@map("content_posts")
}

model Campaign {
  id        Int      @id @default(autoincrement())
  name      String
  platform  String
  goal      String
  status    String   @default("active")
  budget    Float    @default(0)
  createdAt DateTime @default(now())

  content_posts ContentPost[]
}

model Task {
  id         Int       @id @default(autoincrement())
  title      String
  category   String
  status     String    @default("todo")
  assignedTo String?
  dueDate    DateTime?
  createdAt  DateTime  @default(now())
}
